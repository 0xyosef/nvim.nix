{ pkgs, ... }:

let
  inherit (pkgs) vimPlugins;
in
{
  nixvim.plugins = {
    start = [
      vimPlugins.mason-nvim
    ];
  };

  nixvim.config = ''
    lua << EOF
    require("mason").setup({
      ensure_installed = { "lua-language-server", "bash-language-server" },
      automatic_installation = true,
    })
    EOF
  '';
}
